# Vite dev server port (copy this file to `.env` and edit).
# https://vitejs.dev/config/server-options.html#server-port
PORT=3000

# Ollama model used to turn the user question into SearXNG sub-queries (see src/ollama.ts).
SEARCH_FORMULATION_MODEL=mistral:7b

# Prior assistant text budget for that step (newest turn first; larger than PRIOR_ASSISTANT_BUDGET_CHARS is OK).
SEARCH_FORMULATION_PRIOR_BUDGET_CHARS=10000

# Context window for the search-formulation Ollama call (must fit prior thread + latest message).
SEARCH_FORMULATION_NUM_CTX=16384

# Default composer model when Ollama is unreachable or the tag list is empty (see src/modelPicker.ts).
OLLAMA_FALLBACK_MODEL=mistral:7b

# Max characters of prior assistant answers injected before the current turn (newest turn first; see src/ollama.ts).
PRIOR_ASSISTANT_BUDGET_CHARS=6000

# Context window passed to Ollama for the streaming answer request (must be supported by the model).
OLLAMA_ANSWER_NUM_CTX=16384
