# Vite dev server port (copy this file to `.env` and edit).
# https://vitejs.dev/config/server-options.html#server-port
PORT=3000

# Ollama model used to turn the user question into SearXNG sub-queries (see src/ollama.ts).
SEARCH_FORMULATION_MODEL=mistral:7b

# Default composer model when Ollama is unreachable or the tag list is empty (see src/modelPicker.ts).
OLLAMA_FALLBACK_MODEL=mistral:7b
